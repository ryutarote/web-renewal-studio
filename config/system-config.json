{
  "system": {
    "active_account": null,
    "accounts_dir": "accounts",
    "data_dir": "data",
    "mode": "semi_auto"
  },
  "posting": {
    "interval_hours": 2,
    "max_posts_per_day": 10,
    "preferred_hours": [7, 8, 12, 15, 18, 19, 21, 22],
    "timezone": "Asia/Tokyo"
  },
  "quality": {
    "min_score": 7.0,
    "max_similarity": 0.85,
    "scoring_items": [
      "hook_strength",
      "usefulness",
      "specificity",
      "tempo",
      "empathy",
      "originality",
      "cta_strength",
      "target_fit",
      "length_fit",
      "controversy_risk"
    ],
    "max_rewrite_attempts": 2,
    "recent_pattern_check_count": 3,
    "similarity_check_count": 100
  },
  "metrics": {
    "check_intervals_hours": [1, 6, 24],
    "tracked_metrics": ["views", "likes", "replies", "saves"]
  },
  "post_patterns": [
    "short_complete",
    "comment_bait",
    "thread",
    "expose",
    "list",
    "story",
    "comparison",
    "howto",
    "contrarian",
    "data_driven",
    "trend_riding",
    "empathy",
    "provocative",
    "lesson",
    "results_showcase"
  ]
}
